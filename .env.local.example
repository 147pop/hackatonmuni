# ─── MercadoPago ────────────────────────────────────────────────────────────
# Obtener en: https://www.mercadopago.com.ar/developers/panel/app

# Token de acceso (servidor) — NUNCA exponer al cliente
MP_ACCESS_TOKEN=APP_USR-0000000000000000-000000-00000000000000000000000000000000-000000000

# Clave pública (cliente) — segura para exponer
NEXT_PUBLIC_MP_PUBLIC_KEY=APP_USR-00000000-0000-0000-0000-000000000000

# Secreto para validar firma de webhooks (opcional en desarrollo)
MP_WEBHOOK_SECRET=

# URL pública del app (para back_urls y notification_url)
# En desarrollo usar ngrok: ngrok http 3000
APP_URL=https://tu-app.vercel.app

# ─── Simulación (cuando no hay credenciales reales) ──────────────────────────
# Tasa de fallo del mock (0.0 = siempre exitoso, 0.05 = 5% fallos)
NEXT_PUBLIC_MP_MOCK_FAILURE_RATE=0.05
